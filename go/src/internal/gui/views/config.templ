package views

import "strconv"

// ConfigEditor renders the config form. Each field helper takes the schema
// path (trailing args) so number and enum inputs read their min/max/enum
// constraints straight from the JSON Schema.
templ ConfigEditor(data ConfigData, locale Locale) {
	@Layout(locale.T("config.title"), locale, nil) {
		@pageHeader(locale.T("config.title")) {
		}
		<div class="card text-muted config-paths" style="font-size:0.85rem;">
			<strong>{ locale.T("config.config_path") }</strong>
			<code>{ data.ConfigPath }</code>
			<strong>{ locale.T("config.data_dir") }</strong>
			<code>{ data.DataDir }</code>
			<strong>{ locale.T("config.cache_dir") }</strong>
			<code>{ data.CacheDir }</code>
		</div>
		<form id="config-form" method="POST" action="/config">
			<details>
				<summary>{ locale.T("config.general") }</summary>
				<div class="card">
					@textField(data, "meetings_dir", locale.T("config.meetings_dir"), data.V.MeetingsDir)
					@textField(data, "questions_dir", locale.T("config.questions_dir"), data.V.QuestionsDir)
					@textField(data, "reports_dir", locale.T("config.reports_dir"), data.V.ReportsDir)
					@intField(data, locale.T("config.retention_days"), "retention_days", data.V.RetentionDays, "retention_days")
				</div>
			</details>
			<details>
				<summary>{ locale.T("config.bbb") }</summary>
				<div class="card">
					@checkboxField("providers.bbb.enabled", locale.T("config.enabled"), data.V.Providers.BBB.Enabled)
					@textField(data, "providers.bbb.base_url", locale.T("config.bbb_base_url"), data.V.Providers.BBB.BaseURL, "providers", "bbb", "base_url")
					@secretField(data, "providers.bbb.shared_secret", locale.T("config.bbb_shared_secret"), locale.T("config.secret_hint"), "providers", "bbb", "shared_secret")
					@checkboxField("providers.bbb.tls_skip_verify", locale.T("config.tls_skip_verify"), data.V.Providers.BBB.TLSSkipVerify)
					@intField(data, locale.T("config.poll_interval_seconds"), "providers.bbb.poll_interval_seconds", data.V.Providers.BBB.PollIntervalSeconds, "providers", "bbb", "poll_interval_seconds")
				</div>
			</details>
			<details>
				<summary>{ locale.T("config.meet") }</summary>
				<div class="card">
					@checkboxField("providers.meet.enabled", locale.T("config.enabled"), data.V.Providers.Meet.Enabled)
					@textField(data, "providers.meet.oauth.client_id", locale.T("config.oauth_client_id"), data.V.Providers.Meet.OAuth.ClientID)
					@secretField(data, "providers.meet.oauth.client_secret", locale.T("config.oauth_client_secret"), locale.T("config.secret_hint"), "providers", "meet", "oauth", "client_secret")
					@intField(data, locale.T("config.oauth_redirect_port"), "providers.meet.oauth.redirect_port", data.V.Providers.Meet.OAuth.RedirectPort, "providers", "meet", "oauth", "redirect_port")
					@intField(data, locale.T("config.poll_interval_seconds"), "providers.meet.poll_interval_seconds", data.V.Providers.Meet.PollIntervalSeconds, "providers", "meet", "poll_interval_seconds")
				</div>
			</details>
			<details>
				<summary>{ locale.T("config.zoom") }</summary>
				<div class="card">
					@checkboxField("providers.zoom.enabled", locale.T("config.enabled"), data.V.Providers.Zoom.Enabled)
					@textField(data, "providers.zoom.oauth.client_id", locale.T("config.oauth_client_id"), data.V.Providers.Zoom.OAuth.ClientID)
					@secretField(data, "providers.zoom.oauth.client_secret", locale.T("config.oauth_client_secret"), locale.T("config.secret_hint"), "providers", "zoom", "oauth", "client_secret")
					@intField(data, locale.T("config.oauth_redirect_port"), "providers.zoom.oauth.redirect_port", data.V.Providers.Zoom.OAuth.RedirectPort, "providers", "zoom", "oauth", "redirect_port")
					@intField(data, locale.T("config.poll_interval_seconds"), "providers.zoom.poll_interval_seconds", data.V.Providers.Zoom.PollIntervalSeconds, "providers", "zoom", "poll_interval_seconds")
				</div>
			</details>
			<details>
				<summary>{ locale.T("config.telegram") }</summary>
				<div class="card">
					@checkboxField("messengers.telegram.enabled", locale.T("config.enabled"), data.V.Messengers.Telegram.Enabled)
					@secretField(data, "messengers.telegram.bot_token", locale.T("config.tg_bot_token"), locale.T("config.secret_hint"), "messengers", "telegram", "bot_token")
				</div>
			</details>
			<details>
				<summary>{ locale.T("config.challenges") }</summary>
				<div class="card">
					@intField(data, locale.T("config.answer_window"), "challenges.defaults.answer_window_seconds", data.V.Challenges.Defaults.AnswerWindowSeconds, "challenges", "defaults", "answer_window_seconds")
					@intField(data, locale.T("config.min_gap"), "challenges.defaults.min_gap_between_challenges_seconds", data.V.Challenges.Defaults.MinGapBetweenChallengesSecs, "challenges", "defaults", "min_gap_between_challenges_seconds")
					@intField(data, locale.T("config.max_delivery_skew"), "challenges.poll.max_delivery_skew_ms", data.V.Challenges.Poll.MaxDeliverySkewMS, "challenges", "poll", "max_delivery_skew_ms")
				</div>
			</details>
			<details>
				<summary>{ locale.T("config.auto_generation") }</summary>
				<div class="card">
					<div class="text-muted" style="font-size:0.85rem;margin-bottom:0.5rem;">{ locale.T("config.auto_generation.hint") }</div>
					@checkboxField("challenges.auto_generation.enabled", locale.T("config.enabled"), data.V.Challenges.AutoGeneration.Enabled)
					@checkboxField("challenges.auto_generation.auto_submit", locale.T("config.auto_generation.auto_submit"), data.V.Challenges.AutoGeneration.AutoSubmit)
					@intField(data, locale.T("config.auto_generation.poll_interval"), "challenges.auto_generation.poll_interval_seconds", data.V.Challenges.AutoGeneration.PollIntervalSeconds, "challenges", "auto_generation", "poll_interval_seconds")
					@intField(data, locale.T("config.auto_generation.min_words"), "challenges.auto_generation.min_words_per_question", data.V.Challenges.AutoGeneration.MinWordsPerQuestion, "challenges", "auto_generation", "min_words_per_question")
					@intField(data, locale.T("config.auto_generation.max_questions"), "challenges.auto_generation.max_questions_per_poll", data.V.Challenges.AutoGeneration.MaxQuestionsPerPoll, "challenges", "auto_generation", "max_questions_per_poll")
					@textField(data, "challenges.auto_generation.review_dir", locale.T("config.auto_generation.review_dir"), data.V.Challenges.AutoGeneration.ReviewDir, "challenges", "auto_generation", "review_dir")
					<h4>{ locale.T("config.auto_generation.asr") }</h4>
					@textField(data, "challenges.auto_generation.asr.base_url", locale.T("config.auto_generation.base_url"), data.V.Challenges.AutoGeneration.ASR.BaseURL, "challenges", "auto_generation", "asr", "base_url")
					@secretField(data, "challenges.auto_generation.asr.api_key", locale.T("config.auto_generation.api_key"), locale.T("config.secret_hint"), "challenges", "auto_generation", "asr", "api_key")
					@textField(data, "challenges.auto_generation.asr.model", locale.T("config.auto_generation.model"), data.V.Challenges.AutoGeneration.ASR.Model, "challenges", "auto_generation", "asr", "model")
					<h4>{ locale.T("config.auto_generation.llm") }</h4>
					@textField(data, "challenges.auto_generation.llm.base_url", locale.T("config.auto_generation.base_url"), data.V.Challenges.AutoGeneration.LLM.BaseURL, "challenges", "auto_generation", "llm", "base_url")
					@secretField(data, "challenges.auto_generation.llm.api_key", locale.T("config.auto_generation.api_key"), locale.T("config.secret_hint"), "challenges", "auto_generation", "llm", "api_key")
					@textField(data, "challenges.auto_generation.llm.model", locale.T("config.auto_generation.model"), data.V.Challenges.AutoGeneration.LLM.Model, "challenges", "auto_generation", "llm", "model")
					@extraRulesField(locale, data.V.Challenges.AutoGeneration.ExtraRules)
				</div>
			</details>
			<details>
				<summary>{ locale.T("config.gui") }</summary>
				<div class="card">
					@textField(data, "gui.bind_addr", locale.T("config.bind_addr"), data.V.GUI.BindAddr, "gui", "bind_addr")
					@intField(data, locale.T("config.port"), "gui.port", data.V.GUI.Port, "gui", "port")
					@checkboxField("gui.open_browser_on_start", locale.T("config.open_browser"), data.V.GUI.OpenBrowserOnStart)
				</div>
			</details>
			<details>
				<summary>{ locale.T("config.logging") }</summary>
				<div class="card">
					@enumField(data, locale.T("config.log_level"), "logging.level", data.V.Logging.Level, "logging", "level")
					@enumField(data, locale.T("config.log_format"), "logging.format", data.V.Logging.Format, "logging", "format")
					@textField(data, "logging.file", locale.T("config.log_file"), data.V.Logging.File)
				</div>
			</details>
			<div class="config-actions">
				<button id="config-save" type="submit" class="btn btn-primary">{ locale.T("config.save") }</button>
				if data.Error != "" {
					<span class="config-error" role="alert">{ data.Error }</span>
				}
			</div>
		</form>
		<script>
			// Enable Save only once the form is dirty (differs from its loaded
			// snapshot), or immediately if the last save returned an error.
			(function() {
				var form = document.getElementById('config-form');
				if (!form) return;
				var btn = document.getElementById('config-save');
				if (!btn) return;
				var hasError = form.querySelector('.config-error') !== null;
				function snapshot() {
					return new URLSearchParams(new FormData(form)).toString();
				}
				var initial = snapshot();
				btn.disabled = !hasError;
				function check() {
					if (hasError) { btn.disabled = false; return; }
					btn.disabled = snapshot() === initial;
				}
				form.addEventListener('input', check);
				form.addEventListener('change', check);
			})();
		</script>
	}
}

templ textField(data ConfigData, name string, label string, value string, schemaPath ...string) {
	<div class="field">
		<label for={ name }>{ label }</label>
		<input id={ name } name={ name } type="text" value={ value }/>
	</div>
}

// secretField renders an always-empty password input: the stored secret is
// never echoed back, and a blank submit means "keep the existing value".
templ secretField(data ConfigData, name string, label string, hint string, schemaPath ...string) {
	<div class="field">
		<label for={ name }>{ label }</label>
		<input id={ name } name={ name } type="password" value="" autocomplete="new-password" placeholder="••••••••"/>
		<div class="text-muted" style="font-size:0.75rem;margin-top:0.2rem;">{ hint }</div>
	</div>
}

templ intField(data ConfigData, label string, name string, value int, schemaPath ...string) {
	<div class="field">
		<label for={ name }>{ label }</label>
		<input
			id={ name }
			name={ name }
			type="number"
			if min := data.MinAttr(schemaPath...); min != "" {
				min={ min }
			}
			if max := data.MaxAttr(schemaPath...); max != "" {
				max={ max }
			}
			value={ strconv.Itoa(value) }
			style="width:auto;"
		/>
	</div>
}

templ checkboxField(name string, label string, checked bool) {
	<div class="field" style="display:flex;align-items:center;gap:0.5rem;">
		<input
			id={ name }
			name={ name }
			type="checkbox"
			style="width:auto;"
			value="true"
			if checked {
				checked
			}
		/>
		<label for={ name } style="margin:0;">{ label }</label>
	</div>
}

templ enumField(data ConfigData, label string, name string, value string, schemaPath ...string) {
	<div class="field">
		<label for={ name }>{ label }</label>
		<select id={ name } name={ name } style="width:auto;">
			for _, opt := range data.Enum(schemaPath...) {
				<option value={ opt } selected?={ opt == value }>{ opt }</option>
			}
		</select>
	</div>
}

// extraRulesField is a repeatable list of free-text LLM rules. The Add button
// clones the hidden <template> row; all rows share one field name so the
// server collects them into a slice.
templ extraRulesField(locale Locale, rules []string) {
	<div class="field extra-rules" data-extra-rules>
		<label>{ locale.T("config.auto_generation.extra_rules") }</label>
		<div class="text-muted" style="font-size:0.75rem;margin-bottom:0.4rem;">{ locale.T("config.auto_generation.extra_rules.hint") }</div>
		<div class="extra-rules-list" data-extra-rules-list>
			for _, r := range rules {
				@extraRuleRow(locale, r)
			}
		</div>
		<button
			type="button"
			class="btn btn-secondary"
			data-extra-rules-add
			aria-label={ locale.T("config.auto_generation.extra_rules.add") }
			style="margin-top:0.25rem;"
		>+ { locale.T("config.auto_generation.extra_rules.add") }</button>
		<template data-extra-rules-template>
			@extraRuleRow(locale, "")
		</template>
	</div>
	<script>
		(function() {
			document.querySelectorAll('[data-extra-rules]').forEach(function(root) {
				var list = root.querySelector('[data-extra-rules-list]');
				var tpl = root.querySelector('[data-extra-rules-template]');
				root.querySelector('[data-extra-rules-add]').addEventListener('click', function() {
					var clone = tpl.content.firstElementChild.cloneNode(true);
					list.appendChild(clone);
					var input = clone.querySelector('input');
					if (input) input.focus();
					root.dispatchEvent(new Event('input', { bubbles: true }));
				});
				root.addEventListener('click', function(ev) {
					var btn = ev.target.closest('[data-extra-rule-remove]');
					if (!btn) return;
					var row = btn.closest('[data-extra-rule]');
					if (row) row.remove();
					root.dispatchEvent(new Event('input', { bubbles: true }));
				});
			});
		})();
	</script>
}

templ extraRuleRow(locale Locale, value string) {
	<div class="extra-rule-row" data-extra-rule style="display:flex;gap:0.4rem;margin-bottom:0.3rem;">
		<input
			type="text"
			name="challenges.auto_generation.extra_rules"
			value={ value }
			style="flex:1;"
		/>
		<button
			type="button"
			class="btn btn-secondary"
			data-extra-rule-remove
			aria-label={ locale.T("config.auto_generation.extra_rules.remove") }
		>×</button>
	</div>
}
